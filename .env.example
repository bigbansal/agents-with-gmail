# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Gmail OAuth ──────────────────────────────────────────────────────────────
# Path to the OAuth 2.0 client-secret JSON downloaded from Google Cloud Console
GMAIL_CREDENTIALS_PATH=config/credentials.json

# Path where the token will be cached after first authorisation
GMAIL_TOKEN_PATH=config/token.json

# Gmail scopes (space-separated)
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify

# ── Agent behaviour ──────────────────────────────────────────────────────────
# GPT model used for summaries
OPENAI_MODEL=gpt-4o

# Max emails to fetch when building the "day summary"
MAX_EMAILS_FOR_DAY_SUMMARY=20

# Maximum number of attachment pages to parse (per file)
MAX_PDF_PAGES=50
MAX_EXCEL_ROWS=500
